{
  "name": "next-js-linting-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "preview": "next start",
    "lint": "oxlint && eslint --concurrency=auto",
    "lint:fix": "oxlint --fix && eslint --concurrency=auto --fix",
    "lint:ci": "oxlint --deny-warnings && eslint --concurrency=auto",
    "lint:oxlint": "oxlint",
    "lint:eslint": "eslint --concurrency=auto",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:production": "knip --production",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@cspell/eslint-plugin": "^10.0.1",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "16.2.10",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@v2nic/eslint-plugin-prisma": "^2.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-access": "^3.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-oxlint": "^1.72.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-rsc": "^5.10.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-tailwindcss": "^4.0.5",
    "eslint-plugin-unicorn": "^69.0.0",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "prisma": "^6.15.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.6",
    "type-fest": "^5.7.0",
    "typescript": "~6.0.2"
  },
  "overrides": {
    "zod-validation-error": "^4.0.2"
  }
}
