{
  "name": "next-js-linting-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "preview": "next start",
    "analyze": "next experimental-analyze",
    "check": "npm run format && npm run lint:ci && npm run typecheck && npm run test && npm run knip && npm run db:validate",
    "lint": "oxlint && eslint --concurrency=auto --max-warnings=0",
    "lint:fix": "oxlint --fix && eslint --concurrency=auto --fix",
    "lint:ci": "oxlint --deny-warnings && eslint --concurrency=auto --max-warnings=0",
    "lint:oxlint": "oxlint",
    "lint:eslint": "eslint --concurrency=auto --max-warnings=0",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "node --import tsx --test",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:production": "knip --production",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down --volumes",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:check": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "pg": "^8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^10.0.1",
    "@eslint-react/eslint-plugin": "^5.16.1",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@tailwindcss/postcss": "^4.3.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@v2nic/eslint-plugin-prisma": "^2.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-rsc": "^5.16.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-tailwindcss": "^4.2.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "knip": "^6.27.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.10",
    "zod-validation-error": "^4.0.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
